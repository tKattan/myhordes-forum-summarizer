{
  "manifest_version": 3,
  "name": "MyHordes Forum Summarizer",
  "version": "1.0.0",
  "description": "Local-first browser extension for summarizing unread MyHordes forum activity.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://myhordes.eu/*",
        "https://*.myhordes.eu/*"
      ],
      "js": [
        "content/content-script.js"
      ]
    }
  ]
}
